# RSA private key calculation

import math

n = 3599
e = 31

# find p and q
for i in range(2, int(math.sqrt(n)) + 1):
    if n % i == 0:
        p = i
        q = n // i
        break

print("p =", p)
print("q =", q)

# compute phi(n)
phi = (p-1)*(q-1)
print("phi(n) =", phi)


# Extended Euclidean Algorithm
def mod_inverse(e, phi):
    for d in range(1, phi):
        if (e * d) % phi == 1:
            return d

d = mod_inverse(e, phi)

print("Private key (d, n) =", (d, n))
