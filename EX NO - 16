from collections import Counter

# English frequency order
english_order = "ETAOINSHRDLCUMWFGYPBVKJXQZ"

def decrypt(cipher, mapping):
    result = ""
    for c in cipher:
        if c.isalpha():
            result += mapping.get(c, c)
        else:
            result += c
    return result


cipher = input("Enter ciphertext: ").upper()
top_n = int(input("Enter number of possible plaintexts to display: "))

# count frequency of ciphertext letters
freq = Counter([c for c in cipher if c.isalpha()])

# sort ciphertext letters by frequency
cipher_order = "".join([x[0] for x in freq.most_common()])

results = []

for shift in range(len(cipher_order)):
    
    mapping = {}
    
    for i in range(len(cipher_order)):
        if i < len(english_order):
            mapping[cipher_order[i]] = english_order[(i+shift) % 26]

    plaintext = decrypt(cipher, mapping)
    
    results.append(plaintext)

print("\nPossible plaintexts:\n")

for i in range(min(top_n, len(results))):
    print("Option", i+1, ":", results[i])
